<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Коктейль-квиз · НАПИ:БАР</title>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #F5F0E8;
            background-image: radial-gradient(circle at 20% 30%, rgba(233, 30, 99, 0.06) 0%, transparent 35%),
                              radial-gradient(circle at 90% 70%, rgba(45, 45, 45, 0.04) 0%, transparent 45%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 12px;
            color: #2D2D2D;
        }

        .app-screen {
            max-width: 390px;
            width: 100%;
            background: rgba(245, 240, 232, 0.95);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 32px;
            box-shadow: 0 30px 50px -20px rgba(45, 45, 45, 0.25);
            padding: 24px 20px 28px;
            position: relative;
            overflow: hidden;
            transition: opacity 0.25s ease;
            border: 1px solid rgba(45, 45, 45, 0.08);
            min-height: 800px;
            max-height: 844px;
            display: flex;
            flex-direction: column;
        }

        .scene {
            display: none;
            flex-direction: column;
            gap: 20px;
            position: relative;
            z-index: 2;
            flex: 1;
            justify-content: center;
            width: 100%;
            height: 100%;
        }

        .scene.active {
            display: flex;
        }

        h1, h2, h3, p {
            font-weight: 400;
            line-height: 1.3;
            letter-spacing: -0.01em;
        }

        .headline-large {
            font-size: 28px;
            font-weight: 600;
            color: #2D2D2D;
            line-height: 1.2;
            text-align: center;
        }

        .headline-medium {
            font-size: 24px;
            font-weight: 500;
            color: #2D2D2D;
            text-align: center;
        }

        .subhead {
            font-size: 14px;
            font-weight: 400;
            color: #8B7355;
            text-align: center;
            line-height: 1.5;
        }

        .micro-text {
            font-size: 11px;
            font-weight: 400;
            color: #8B7355;
            opacity: 0.85;
            letter-spacing: 0.2px;
            text-align: center;
        }

        .brand-logo {
            position: absolute;
            top: 20px;
            left: 24px;
            z-index: 10;
            font-size: 16px;
            font-weight: 600;
            color: #2D2D2D;
            letter-spacing: 0.5px;
        }

        .brand-logo span {
            color: #E91E6D;
        }

        .cocktail-image-large {
            width: 100%;
            max-width: 220px;
            aspect-ratio: 3/4;
            margin: 8px auto 16px;
            border-radius: 120px 120px 50px 50px;
            box-shadow: 0 20px 40px -15px rgba(45, 45, 45, 0.2);
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(45, 45, 45, 0.1);
            background-size: cover;
            background-position: center;
            background-color: #F5F0E8;
        }

        .cocktail-story-image {
            width: 180px;
            height: 240px;
            margin: 8px auto 16px;
            border-radius: 120px 120px 50px 50px;
            box-shadow: 0 24px 36px -18px rgba(45, 45, 45, 0.3);
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(45, 45, 45, 0.12);
            background-size: cover;
            background-position: center;
            background-color: #F5F0E8;
        }

        .section-divider {
            width: 100%;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(45, 45, 45, 0.15), transparent);
            margin: 16px 0;
        }

        .bonus-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 16px 18px;
            border: 1px solid rgba(45, 45, 45, 0.08);
            box-shadow: 0 6px 18px -10px rgba(45, 45, 45, 0.1);
            width: 100%;
            text-align: center;
        }

        .bonus-title {
            font-size: 10px;
            font-weight: 600;
            color: #2D2D2D;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.6;
        }

        .promo-code {
            font-size: 24px;
            font-weight: 700;
            color: #E91E6D;
            letter-spacing: 1.5px;
            background: rgba(245, 240, 232, 0.95);
            border-radius: 10px;
            padding: 8px 16px;
            display: inline-block;
            margin: 4px 0 6px;
            border: 1.5px dashed #E91E6D;
            font-family: 'Inter', monospace;
        }

        .promo-valid {
            font-size: 10px;
            color: #8B7355;
            margin-bottom: 2px;
            font-weight: 400;
        }
        
        .promo-helper {
            font-size: 9px;
            color: #2D2D2D;
            opacity: 0.5;
            font-weight: 400;
        }

        .button-container {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-top: 4px;
        }

        .button-row {
            display: flex;
            gap: 10px;
            width: 100%;
        }

        .button-large {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            border-radius: 100px;
            padding: 14px 18px;
            font-size: 14px;
            font-weight: 500;
            text-align: center;
            transition: all 0.18s cubic-bezier(0.2, 0.9, 0.3, 1.1);
            border: none;
            cursor: pointer;
            position: relative;
        }

        .btn-primary {
            background: #2D2D2D;
            color: #F5F0E8;
            box-shadow: 0 4px 14px rgba(45, 45, 45, 0.25);
            flex: 1.2;
        }

        .btn-primary:active {
            transform: scale(0.97);
            background: #1a1a1a;
        }

        .btn-secondary {
            background: rgba(245, 240, 232, 0.85);
            color: #2D2D2D;
            border: 1.5px solid rgba(45, 45, 45, 0.15);
            backdrop-filter: blur(4px);
            font-weight: 500;
            flex: 1;
        }

        .btn-secondary:active {
            background: #F5F0E8;
            border-color: #E91E6D;
            transform: scale(0.97);
        }

        .btn-helper {
            font-size: 9px;
            color: #8B7355;
            text-align: center;
            margin-top: -2px;
            opacity: 0.8;
            font-weight: 400;
            line-height: 1.2;
        }

        .centered {
            text-align: center;
            align-items: center;
        }

        .story-container {
            background: rgba(245, 240, 232, 0.85);
            backdrop-filter: blur(20px);
            border-radius: 40px;
            padding: 28px 18px 36px;
            margin: 0 0 10px;
            border: 1px solid rgba(45, 45, 45, 0.12);
            box-shadow: 0 20px 40px -18px rgba(45, 45, 45, 0.25);
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
        }

        .story-top-text {
            font-size: 12px;
            font-weight: 500;
            color: #8B7355;
            letter-spacing: 1px;
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        .story-headline {
            font-size: 36px;
            font-weight: 600;
            color: #2D2D2D;
            line-height: 1.1;
            margin: 6px 0 4px;
        }

        .story-subhead {
            font-size: 16px;
            font-weight: 400;
            color: #8B7355;
            max-width: 260px;
            margin: 0 auto 14px;
            line-height: 1.4;
        }

        .story-footer {
            font-size: 12px;
            color: #2D2D2D;
            margin-top: 24px;
            font-weight: 400;
            letter-spacing: 0.3px;
            opacity: 0.7;
        }

        .confirmation-icon {
            font-size: 48px;
            margin-bottom: 6px;
            filter: drop-shadow(0 4px 8px rgba(233, 30, 109, 0.2));
        }

        .fade-in {
            animation: softAppear 0.35s ease-out;
        }

        @keyframes softAppear {
            0% { opacity: 0.5; transform: translateY(8px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        @keyframes bubbleUp {
            0%,80%,100% { transform: scale(0.6); opacity: 0.2; }
            40% { transform: scale(1.1); opacity: 0.7; }
        }

        .hidden-nav {
            display: flex;
            justify-content: center;
            gap: 5px;
            margin-top: 14px;
            z-index: 2;
        }
        .dot {
            width: 5px;
            height: 5px;
            background: #8B7355;
            opacity: 0.35;
            border-radius: 10px;
        }

        .option-with-desc {
            cursor: pointer;
            transition: transform 0.12s, background 0.12s;
        }
        .option-with-desc:active {
            transform: scale(0.98);
            background: rgba(245, 240, 232, 0.95);
        }

        #storyCardContainer {
            position: fixed;
            top: -9999px;
            left: -9999px;
            width: 1080px;
            height: 1920px;
            background: #F5F0E8;
            z-index: 9999;
        }

        .story-card {
            width: 1080px;
            height: 1920px;
            background: linear-gradient(180deg, #F5F0E8 0%, #EBE5DC 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 80px 60px;
            position: relative;
        }

        .story-card-logo {
            font-size: 48px;
            font-weight: 700;
            color: #2D2D2D;
            margin-bottom: 60px;
            letter-spacing: 2px;
        }

        .story-card-logo span {
            color: #E91E6D;
        }

        .story-card-image {
            width: 720px;
            height: 960px;
            border-radius: 360px 360px 180px 180px;
            overflow: hidden;
            margin-bottom: 60px;
            box-shadow: 0 40px 100px -30px rgba(45, 45, 45, 0.3);
            border: 3px solid rgba(45, 45, 45, 0.08);
        }

        .story-card-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .story-card-title {
            font-size: 72px;
            font-weight: 700;
            color: #2D2D2D;
            text-align: center;
            margin-bottom: 20px;
            line-height: 1.1;
        }

        .story-card-subtitle {
            font-size: 32px;
            font-weight: 400;
            color: #8B7355;
            text-align: center;
            max-width: 800px;
            line-height: 1.4;
            margin-bottom: 60px;
        }

        .story-card-promo {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(10px);
            border-radius: 40px;
            padding: 50px 60px;
            border: 3px dashed #E91E6D;
            text-align: center;
            margin-bottom: 60px;
        }

        .story-card-promo-title {
            font-size: 32px;
            font-weight: 600;
            color: #2D2D2D;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 25px;
            opacity: 0.7;
        }

        .story-card-promo-code {
            font-size: 90px;
            font-weight: 700;
            color: #E91E6D;
            letter-spacing: 5px;
            font-family: 'Inter', monospace;
        }

        .story-card-promo-valid {
            font-size: 28px;
            color: #8B7355;
            margin-top: 20px;
            font-weight: 400;
        }

        .story-card-footer {
            font-size: 28px;
            color: #2D2D2D;
            opacity: 0.5;
            margin-top: auto;
            font-weight: 400;
        }

        .story-card-brand {
            position: absolute;
            bottom: 60px;
            font-size: 32px;
            font-weight: 500;
            color: #8B7355;
            letter-spacing: 1px;
        }

        /* Avatar Style */
        .avatar-circle {
            width: 300px;
            height: 300px;
            border-radius: 50% 50% 40% 40% / 60% 60% 50% 50%;
            border: 2px solid rgba(45, 45, 45, 0.1);
            background: rgba(245, 240, 232, 0.5);
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .avatar-circle img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            border-radius: 50% 50% 40% 40% / 60% 60% 50% 50%;
        }
    </style>
</head>
<body>
    <div class="app-screen" id="appScreen">
        <div class="brand-logo">НАПИ:<span>БАР</span></div>

        <!-- СЦЕНА 1: ВХОД -->
        <div class="scene active centered" id="scene1">
            <div style="flex: 1; display: flex; flex-direction: column; justify-content: center;">
                <h1 class="headline-large">Весна начинается с тебя</h1>
                <p class="subhead">с того, какой ты сегодня</p>
                <div style="margin: 40px 0 20px; width: 100%;">
                    <button class="button-large btn-primary" id="btnStart">Узнать свой вкус</button>
                </div>
            </div>
        </div>

        <!-- СЦЕНА 2: ВОПРОС 1 -->
        <div class="scene centered" id="scene2">
            <div style="flex: 1; display: flex; flex-direction: column; justify-content: center;">
                <h2 class="headline-medium">Твоя среда — какая она?</h2>
                <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 24px; width: 100%;">
                    <button class="button-large btn-secondary btn-q2" data-type="party">Как маленькая пятница 🎉</button>
                    <button class="button-large btn-secondary btn-q2" data-type="calm">Тихая гавань 🌿</button>
                    <button class="button-large btn-secondary btn-q2" data-type="surprise">День сюрпризов ✨</button>
                    <button class="button-large btn-secondary btn-q2" data-type="light">Лёгкий бриз 🍃</button>
                </div>
            </div>
        </div>

        <!-- СЦЕНА 3: ВОПРОС 2 -->
        <div class="scene centered" id="scene3">
            <div style="flex: 1; display: flex; flex-direction: column; justify-content: center;">
                <h2 class="headline-medium">Какой вкус тебе ближе?</h2>
                <div class="option-stack" style="display: flex; flex-direction: column; gap: 12px; margin-top: 24px; width: 100%;">
                    <div class="option-with-desc" data-type="berry" style="background: rgba(245, 240, 232, 0.75); backdrop-filter: blur(4px); border-radius: 24px; padding: 18px 22px; border: 1px solid rgba(45, 45, 45, 0.12);">
                        <p style="font-size:17px; color:#2D2D2D; font-weight: 500; margin-bottom: 4px;">Ягодная свежесть</p>
                        <p class="micro-text">сладость с лёгкой терпкостью</p>
                    </div>
                    <div class="option-with-desc" data-type="citrus" style="background: rgba(245, 240, 232, 0.75); backdrop-filter: blur(4px); border-radius: 24px; padding: 18px 22px; border: 1px solid rgba(45, 45, 45, 0.12);">
                        <p style="font-size:17px; color:#2D2D2D; font-weight: 500; margin-bottom: 4px;">Цитрус и кофе</p>
                        <p class="micro-text">сладкий, мягкий, согревающий</p>
                    </div>
                    <div class="option-with-desc" data-type="herb" style="background: rgba(245, 240, 232, 0.75); backdrop-filter: blur(4px); border-radius: 24px; padding: 18px 22px; border: 1px solid rgba(45, 45, 45, 0.12);">
                        <p style="font-size:17px; color:#2D2D2D; font-weight: 500; margin-bottom: 4px;">Травы и яблоко</p>
                        <p class="micro-text">свежий, с мягкой кислинкой</p>
                    </div>
                    <div class="option-with-desc" data-type="pepper" style="background: rgba(245, 240, 232, 0.75); backdrop-filter: blur(4px); border-radius: 24px; padding: 18px 22px; border: 1px solid rgba(45, 45, 45, 0.12);">
                        <p style="font-size:17px; color:#2D2D2D; font-weight: 500; margin-bottom: 4px;">Клубника и перец</p>
                        <p class="micro-text">яркий, кислый, неожиданный</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- СЦЕНА 4: ВОПРОС 3 -->
        <div class="scene centered" id="scene4">
            <div style="flex: 1; display: flex; flex-direction: column; justify-content: center;">
                <h2 class="headline-medium">Идеальный вечер — это:</h2>
                <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 24px; width: 100%;">
                    <button class="button-large btn-secondary btn-q4" data-type="party">Весёлый и шумный 🎉</button>
                    <button class="button-large btn-secondary btn-q4" data-type="calm">Спокойный и уютный 🕯️</button>
                    <button class="button-large btn-secondary btn-q4" data-type="surprise">С неожиданностями 🎲</button>
                    <button class="button-large btn-secondary btn-q4" data-type="light">Лёгкий и непринуждённый 🍃</button>
                </div>
            </div>
        </div>

        <!-- СЦЕНА 5: ЗАГРУЗКА -->
        <div class="scene centered" id="scene5">
            <div style="flex:1; display: flex; flex-direction: column; justify-content: center; align-items: center;">
                <h2 class="headline-medium" style="margin-bottom: 32px;">Подбираем коктейль...</h2>
                <div style="display: flex; gap: 16px; justify-content: center; margin: 30px 0;">
                    <div style="width:14px; height:14px; background:#E91E6D; border-radius:50%; animation: bubbleUp 1.4s infinite both; animation-delay:-0.3s;"></div>
                    <div style="width:14px; height:14px; background:#8B7355; border-radius:50%; animation: bubbleUp 1.4s infinite both; animation-delay:-0.1s;"></div>
                    <div style="width:14px; height:14px; background:#2D2D2D; border-radius:50%; animation: bubbleUp 1.4s infinite both; animation-delay:0.1s;"></div>
                </div>
            </div>
        </div>

        <!-- СЦЕНА 6: РЕЗУЛЬТАТ (FINAL DESIGN) -->
        <div class="scene centered" id="scene6">
            <div style="flex: 1; display: flex; flex-direction: column; justify-content: flex-start; align-items: stretch; width: 100%; padding-top: 40px; gap: 24px;">
                <!-- Avatar + Result -->
                <div style="display: flex; flex-direction: column; align-items: center; gap: 12px;">
                    <div class="avatar-circle" style="margin-bottom: 8px;">
                        <img id="resultAvatarImage" src="" alt="Avatar" style="display:none; width: 100%; height: 100%; object-fit: cover;">
                        <span id="resultAvatarPlaceholder" style="display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; font-size: 32px; color: #2D2D2D; opacity: 0.5;">Cocktail</span>
                    </div>
                    
                    <h1 class="headline-large" id="resultTitle" style="margin-top: 8px;">Ты — Коктейль</h1>
                    <p class="subhead" id="resultDesc" style="max-width: 280px;">Описание</p>
                </div>

                <!-- Buttons -->
                <div class="button-container" style="margin-top: 0; margin-bottom: 8px;">
                    <div class="button-row">
                        <button class="button-large btn-primary" id="shareResultBtn">
                            Поделиться в Telegram
                        </button>
                    </div>
                    <div style="display: flex; justify-content: center; padding: 0 8px;">
                        <div class="btn-helper" style="text-align: center;">Поделиться квизом с друзьями</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- СЦЕНА 7: ПОДТВЕРЖДЕНИЕ -->
        <div class="scene centered" id="scene7">
            <div style="flex: 1; display: flex; flex-direction: column; justify-content: center;">
                <div class="story-container">
                    <div class="story-top-text">НАПИ:БАР — Весенний квиз</div>
                    <div class="cocktail-story-image" id="storyImage"></div>
                    <div class="story-headline" id="storyTitle">Твой коктейль</div>
                    <div class="story-subhead" id="storyDesc">Описание</div>
                    <div class="story-footer">Узнай, кто ты этой весной</div>
                </div>
                
                <div style="margin-top: 18px; width: 100%;">
                    <div class="confirmation-icon">✨🎉</div>
                    <h2 class="headline-medium" style="margin-bottom: 4px; font-size: 24px;">Готово!</h2>
                    <p class="subhead" style="max-width: 250px; margin: 0 auto 16px;">Отправь другу и узнайте, кто вы этой весной</p>
                    <button class="button-large btn-secondary" style="max-width: 190px; margin: 12px auto;" id="backToResultBtn">Вернуться</button>
                </div>
            </div>
        </div>

        <div class="hidden-nav">
            <span class="dot"></span><span class="dot"></span><span class="dot"></span><span class="dot"></span><span class="dot"></span><span class="dot"></span><span class="dot"></span>
        </div>
    </div>

    <!-- Story Card Container for PDF Generation -->
    <div id="storyCardContainer">
        <div class="story-card" id="storyCard">
            <div class="story-card-logo">НАПИ:<span>БАР</span></div>
            
            <div class="story-card-image">
                <img id="storyCardImg" src="" alt="Cocktail" style="display: none;">
                <div id="storyCardAvatarContainer" style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: rgba(245, 240, 232, 0.3);">
                    <img id="storyCardAvatarImg" src="" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover; display: none;">
                    <span id="storyCardAvatarPlaceholder" style="font-size: 120px; color: #2D2D2D; opacity: 0.3; font-weight: 600;">Cocktail</span>
                </div>
            </div>
            
            <div class="story-card-title" id="storyCardTitle">Твой коктейль</div>
            <div class="story-card-subtitle" id="storyCardDesc">Описание</div>
            
            <div class="story-card-promo">
                <div class="story-card-promo-title">Весенний бонус</div>
                <div class="story-card-promo-code" id="storyCardPromoCode">SPRINGNAPI</div>
                <div class="story-card-promo-valid">Действует до 31 марта</div>
            </div>
            
            <div class="story-card-footer">НАПИ:БАР — Весенний квиз 2025</div>
            <div class="story-card-brand">napibar.ru</div>
        </div>
    </div>

    <script>
        const cocktailResults = {
            cocktail68: {
                name: 'Клубничный Имбирь #68',
                desc: 'Свежий ягодный коктейль с легкой пряностью и ароматом зелени',
                image: '<%= safe_asset_path('cocktails/cocktail68.png') %>',
                types: ['berry', 'party', 'light']
            },
            cocktail69: {
                name: 'Апельсин Кофе #69',
                desc: 'Свежий, легкий сладкий коктейль с апельсиново-кофейным вкусом',
                image: '<%= safe_asset_path('cocktails/cocktail69.png') %>',
                types: ['citrus', 'calm', 'surprise']
            },
            cocktail70: {
                name: 'Яблоко Травы #70',
                desc: 'Свежий травянистый коктейль с мягким яблочным послевкусием и приятно кислинкой',
                image: '<%= safe_asset_path('cocktails/cocktail70.png') %>',
                types: ['herb', 'calm', 'light']
            },
            cocktail71: {
                name: 'Клубника Перец #71',
                desc: 'Свежий, кислый, легкий коктейль с ярким вкусом клубники, болгарского перца и приятной кислинкой',
                image: '<%= safe_asset_path('cocktails/cocktail71.png') %>',
                types: ['pepper', 'party', 'surprise']
            },
            shot1: {
                name: 'Шот Бамбл',
                desc: 'Крепкий кисло-сладкий шот',
                image: '<%= safe_asset_path('cocktails/shot1.png') %>',
                types: ['citrus', 'party', 'surprise']
            },
            shot2: {
                name: 'Шот Укроп',
                desc: 'Свежий шот, средней крепости',
                image: '<%= safe_asset_path('cocktails/shot2.png') %>',
                types: ['citrus', 'calm', 'light']
            },
            shot3: {
                name: 'Шот Лимонно Травяной',
                desc: 'Крепкий, пряный шот с приятной кислинкой',
                image: '<%= safe_asset_path('cocktails/shot3.png') %>',
                types: ['herb', 'party', 'surprise']
            },
            shot4: {
                name: 'Шот Барбарис',
                desc: 'Легкий, кисло сладкий ягодный шот',
                image: '<%= safe_asset_path('cocktails/shot4.png') %>',
                types: ['citrus', 'light', 'party']
            }
        };

        let userAnswers = { q1: null, q2: null, q3: null };
        let quizStartedAt = null;
        let currentResult = null;

        function calculateResult() {
            const answers = [userAnswers.q1, userAnswers.q2, userAnswers.q3];
            const typeCount = {};
            
            answers.forEach(type => {
                if (type) {
                    typeCount[type] = (typeCount[type] || 0) + 1;
                }
            });

            let bestMatch = null;
            let bestScore = 0;

            for (const [key, cocktail] of Object.entries(cocktailResults)) {
                let score = 0;
                cocktail.types.forEach(type => {
                    if (typeCount[type]) {
                        score += typeCount[type] * 2;
                    }
                });
                score += Math.random() * 1.5;

                if (score > bestScore) {
                    bestScore = score;
                    bestMatch = cocktail;
                }
            }

            if (!bestMatch || bestScore === 0) {
                const keys = Object.keys(cocktailResults);
                bestMatch = cocktailResults[keys[Math.floor(Math.random() * keys.length)]];
            }

            return bestMatch;
        }

        function updateResultUI(cocktail) {
            document.getElementById('resultTitle').textContent = `Ты — ${cocktail.name}`;
            document.getElementById('resultDesc').textContent = cocktail.desc;
            document.getElementById('storyTitle').textContent = `Ты — ${cocktail.name}`;
            document.getElementById('storyDesc').textContent = cocktail.desc;
            document.getElementById('storyCardTitle').textContent = `Ты — ${cocktail.name}`;
            document.getElementById('storyCardDesc').textContent = cocktail.desc;
            document.getElementById('storyCardImg').src = cocktail.image;

            const storyImage = document.getElementById('storyImage');
            storyImage.style.backgroundImage = `url('${cocktail.image}')`;
            
            // Обновляем промокод в PDF карточке
            const promoCode = document.getElementById('storyCardPromoCode');
            if (promoCode) {
                promoCode.textContent = 'SPRINGNAPI';
            }
            
            // Обновляем аватар в PDF карточке
            setTimeout(() => {
                updateStoryCardAvatar();
            }, 300);
            
            // Сохраняем результат для отправки в БД
            currentResult = cocktail;
            
            // Сохраняем результат в БД
            saveQuizResult(cocktail);
        }
        
        function updateStoryCardAvatar() {
            const avatarImg = document.getElementById('resultAvatarImage');
            const storyCardAvatarImg = document.getElementById('storyCardAvatarImg');
            const storyCardAvatarPlaceholder = document.getElementById('storyCardAvatarPlaceholder');
            
            if (avatarImg && avatarImg.src && avatarImg.style.display !== 'none' && avatarImg.src !== window.location.href) {
                // Аватар есть - показываем его в PDF
                if (storyCardAvatarImg) {
                    storyCardAvatarImg.src = avatarImg.src;
                    storyCardAvatarImg.style.display = 'block';
                }
                if (storyCardAvatarPlaceholder) {
                    storyCardAvatarPlaceholder.style.display = 'none';
                }
            } else {
                // Аватара нет - показываем placeholder
                if (storyCardAvatarImg) {
                    storyCardAvatarImg.style.display = 'none';
                }
                if (storyCardAvatarPlaceholder) {
                    storyCardAvatarPlaceholder.style.display = 'block';
                }
            }
        }
        
        function updateAvatarUI(avatarUrl) {
            const img = document.getElementById('resultAvatarImage');
            const placeholder = document.getElementById('resultAvatarPlaceholder');
            
            if (avatarUrl) {
                img.src = avatarUrl;
                img.style.display = 'block';
                if (placeholder) placeholder.style.display = 'none';
                
                // Обновляем аватар в PDF карточке
                setTimeout(() => {
                    updateStoryCardAvatar();
                }, 300);
            } else {
                img.style.display = 'none';
                if (placeholder) {
                    placeholder.style.display = 'block';
                    placeholder.textContent = 'Cocktail';
                }
                updateStoryCardAvatar();
            }
        }
        
        async function saveQuizResult(cocktail) {
            try {
                // Получаем данные пользователя из Telegram WebApp
                let telegramUser = null;
                if (window.Telegram && window.Telegram.WebApp) {
                    telegramUser = window.Telegram.WebApp.initDataUnsafe?.user;
                }
                
                // Если нет данных из Telegram, создаем минимальный объект
                if (!telegramUser) {
                    telegramUser = {
                        id: Date.now(), // Временный ID
                        first_name: 'Гость',
                        username: null,
                        last_name: null,
                        language_code: 'ru'
                    };
                }
                
                // Обновляем аватар на фронте, если Telegram прислал ссылку
                if (telegramUser.photo_url) {
                    updateAvatarUI(telegramUser.photo_url);
                } else {
                    updateAvatarUI(null);
                }
                
                const payload = {
                    telegram_user: telegramUser,
                    result_type: cocktail.name.includes('Шот') ? 'shot' : 'cocktail',
                    result_label: cocktail.name,
                    answers: userAnswers,
                    started_at: quizStartedAt ? new Date(quizStartedAt).toISOString() : new Date().toISOString(),
                    source: 'organic'
                };
                
                const response = await fetch('/api/quiz_sessions', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || ''
                    },
                    body: JSON.stringify(payload)
                });
                
                const data = await response.json();
                
                if (response.ok) {
                    console.log('Результат квиза сохранен:', data);
                } else {
                    console.warn('Не удалось сохранить результат:', data);
                    // Не показываем ошибку пользователю, чтобы не портить UX
                }
            } catch (error) {
                console.error('Ошибка при сохранении результата:', error);
                // Не показываем ошибку пользователю
            }
        }

        (function() {
            const scenes = {
                1: document.getElementById('scene1'),
                2: document.getElementById('scene2'),
                3: document.getElementById('scene3'),
                4: document.getElementById('scene4'),
                5: document.getElementById('scene5'),
                6: document.getElementById('scene6'),
                7: document.getElementById('scene7')
            };

            function showScene(sceneId) {
                Object.values(scenes).forEach(s => s.classList.remove('active'));
                const next = scenes[sceneId];
                if (next) {
                    next.classList.add('active');
                    next.classList.add('fade-in');
                    setTimeout(() => next.classList.remove('fade-in'), 350);
                }
                if (sceneId === 5) {
                    if (window.loadingTimer) clearTimeout(window.loadingTimer);
                    window.loadingTimer = setTimeout(() => {
                        if (scenes[5].classList.contains('active')) {
                            const result = calculateResult();
                            updateResultUI(result);
                            showScene(6);
                        }
                    }, 2000);
                }
            }
            window.showScene = showScene;

            document.getElementById('btnStart').addEventListener('click', () => {
                userAnswers = { q1: null, q2: null, q3: null };
                quizStartedAt = new Date().toISOString(); // Запоминаем время начала
                showScene(2);
            });

            document.querySelectorAll('#scene2 .btn-q2').forEach(btn => {
                btn.addEventListener('click', function() {
                    userAnswers.q1 = this.getAttribute('data-type');
                    showScene(3);
                });
            });

            document.querySelectorAll('#scene3 .option-with-desc').forEach(opt => {
                opt.addEventListener('click', function() {
                    userAnswers.q2 = this.getAttribute('data-type');
                    showScene(4);
                });
            });

            document.querySelectorAll('#scene4 .btn-q4').forEach(btn => {
                btn.addEventListener('click', function() {
                    userAnswers.q3 = this.getAttribute('data-type');
                    showScene(5);
                });
            });

            document.getElementById('shareResultBtn').addEventListener('click', async () => {
                try {
                    const resultTitleEl = document.getElementById('resultTitle');
                    const resultName = resultTitleEl
                        ? resultTitleEl.textContent.replace('Ты — ', '').trim()
                        : '';

                    // Прямой URL на бота (при нажатии кнопки открывается бот)
                    const botUrl = 'https://t.me/springbonus_bot';

                    // Текст для шеринга (без ссылок, только текст):
                    // Я — {коктейль} 🍹
                    // А ты какой? Пройти квиз: @springbonus_bot
                    const shareText = `Я — ${resultName} 🍹\nА ты какой? Пройти квиз: @springbonus_bot`;

                    // Формируем URL для шеринга через Telegram
                    // Параметр url создаст превью-карточку с кнопкой "Открыть" для перехода в бота
                    // Параметр text содержит только текст без ссылок
                    const telegramShareUrl =
                        `https://t.me/share/url?url=${encodeURIComponent(botUrl)}&text=${encodeURIComponent(shareText)}`;

                    // Проверяем, запущено ли приложение в Telegram
                    if (window.Telegram && window.Telegram.WebApp) {
                        const tg = window.Telegram.WebApp;
                        
                        // Используем openTelegramLink для открытия диалога выбора контактов
                        tg.openTelegramLink(telegramShareUrl);
                    } else {
                        // Fallback: Используем window.open если не в WebApp
                        window.open(telegramShareUrl, '_blank');
                    }

                    showScene(7);
                } catch (err) {
                    console.error('Ошибка при шеринге:', err);
                    // Fallback: копируем ссылку на бота в буфер обмена
                    try {
                        const fallbackUrl = 'https://t.me/springbonus_bot';
                        await navigator.clipboard.writeText(fallbackUrl);
                        showScene(7);
                    } catch (clipErr) {
                        alert('Не удалось поделиться. Попробуйте еще раз.');
                    }
                }
            });

            document.getElementById('backToResultBtn').addEventListener('click', () => showScene(6));

            // Инициализация Telegram Web App
            if (window.Telegram && window.Telegram.WebApp) {
                const tg = window.Telegram.WebApp;
                tg.ready();
                tg.expand();
                
                // Настройка цветов темы
                tg.setHeaderColor('#F5F0E8');
                tg.setBackgroundColor('#F5F0E8');
                
                // Можно использовать данные пользователя
                const user = tg.initDataUnsafe?.user;
                if (user) {
                    console.log('Telegram user:', user);
                }
                
                // Включить закрытие по кнопке назад
                tg.enableClosingConfirmation();
            }

            showScene(1);
        })();
    </script>
</body>
</html>
